# ---- Supabase (create a project, copy from Settings → API / Database) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # secret — server only

# Postgres connections (Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres.<ref>:<pw>@<host>:6543/postgres?pgbouncer=true   # transaction pooler (runtime)
DIRECT_URL=postgresql://postgres.<ref>:<pw>@<host>:5432/postgres                    # direct (migrations)

# ---- App ----
API_KEYS_ENCRYPTION_SECRET=generate-a-long-random-string  # encrypts api_keys at rest
CRON_SECRET=generate-a-long-random-string                 # protects /api/cron/* in prod
ADMIN_EMAILS=stephen@studio-flow.co                       # comma list → role=admin on first login

# ---- Provider keys (optional here; preferably managed in the Admin Panel api_keys table) ----
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# APIFY_TOKEN=
